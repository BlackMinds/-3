# Dependencies
node_modules/

# Nuxt build
.nuxt/
.output/
.data/

# Vercel build output
.vercel/

# Build output
dist/
dist-ssr/

# Environment variables (contains secrets)
.env
.env.*
!.env.example

# Database dump (contains user data, too large for git)
*.sql
!server/database/migration.sql

# Legacy code (old Vue+Express project, kept locally for reference)
_legacy/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# Claude Code local settings (整个 .claude 目录都是本地个人配置)
.claude/

# Local overrides
*.local

# 浏览器自测产物 (agent-browser 截图/视频)
dogfood-output/

# 本地开发/测试辅助脚本 (连本地数据库 / 依赖测试种子数据 / 一次性迁移)
scripts/test/
scripts/*.mjs
!scripts/migrate.mjs

# 测试账号快照 (dump 出来的临时统计, 由 scripts/dump-test-accounts.mjs 生成)
design/test-accounts.txt
