  "scaling_rules": {
    "description": "强化与 T 级作用域不重叠（基础属性1 为交集）",
    "enhance_affects": ["base_stat_1", "enhance_affix"],
    "tier_affects": ["base_stat_1", "wuxing_affix"],
    "baseline_setup": "满级满修 T15 + 9 红装、6 件触发 3 个五行词条 + 1 件不触发；副词条 21 会心率 + 21 会心伤害 + 6 五行强化 + 20 吸血 + 8 闪避 + 8 命中 + 9 破甲（含等级/境界，不计功法被动）",
    "enhance_level_cap": 9,
    "diff_vs_v4": "V4 现役 enhance cap = +15（shared/balance.ts:ENHANCE_SELL_MUL）；V5 baseline 是 +9 满强化，cap 下调到 +9"
  },

  "base_stat_1_enhance_curve": {
    "formula_zh": "基础属性1 强化倍率 = 1 + level × 0.10（沿用 V4 ENHANCE_MUL_PER_LEVEL，cap 下调到 +9）",
    "per_level_mul": 0.10,
    "mul_table": {
      "_layout": "{ level: mul }，level 0~9",
      "0": 1.00,
      "1": 1.10,
      "2": 1.20,
      "3": 1.30,
      "4": 1.40,
      "5": 1.50,
      "6": 1.60,
      "7": 1.70,
      "8": 1.80,
      "9": 1.90
    },
    "single_piece_formula": "single_piece_base_stat_1 = base_value(stat) × tier_weight(T) × rarity_mul(color) × (1 + level × 0.10)",
    "note": "本曲线只作用于「基础属性1」；五行词条与强化词条不受影响，五行词条只看 T 级，强化词条只看 enhance_affix.unlock_levels"
  },

