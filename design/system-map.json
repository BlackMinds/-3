{
  "system_id": "map",
  "system_name": "地图历练系统",
  "priority": "P0",
  "description": "玩家自由选择地图挂机打怪，怪物属性随机浮动，怪物拥有技能会在战斗中使用",

  "monster_generation": {
    "description": "怪物生成规则，基于模板数值随机浮动，并从技能池分配技能",
    "stat_randomization": {
      "description": "每次遭遇怪物时，基于模板数值随机浮动",
      "fluctuation_range": 0.15,
      "formula": "actual_value = base_value * random(1 - range, 1 + range)",
      "affected_stats": ["HP", "ATK", "DEF", "SPD"],
      "exp_fluctuation": 0.10,
      "spirit_stone_fluctuation": 0.20,
      "examples": [
        { "base_power": 1000, "actual_range": [850, 1150], "note": "±15%浮动" },
        { "base_exp": 100, "actual_range": [90, 110], "note": "经验±10%" }
      ]
    },
    "stat_distribution": {
      "description": "怪物的power值按比例分配到四维属性",
      "formula": {
        "HP": "power * hp_ratio * 10",
        "ATK": "power * atk_ratio",
        "DEF": "power * def_ratio * 0.6",
        "SPD": "power * spd_ratio * 0.3"
      },
      "role_ratios": {
        "balanced":  { "hp_ratio": 0.30, "atk_ratio": 0.30, "def_ratio": 0.25, "spd_ratio": 0.15 },
        "tank":      { "hp_ratio": 0.40, "atk_ratio": 0.15, "def_ratio": 0.35, "spd_ratio": 0.10 },
        "dps":       { "hp_ratio": 0.20, "atk_ratio": 0.45, "def_ratio": 0.15, "spd_ratio": 0.20 },
        "speed":     { "hp_ratio": 0.20, "atk_ratio": 0.25, "def_ratio": 0.15, "spd_ratio": 0.40 },
        "boss":      { "hp_ratio": 0.35, "atk_ratio": 0.30, "def_ratio": 0.25, "spd_ratio": 0.10 }
      }
    },
    "skill_assignment": {
      "description": "怪物根据tier和属性从技能池获取技能",
      "rules": {
        "tier_1_2": { "skill_count": 1, "pool": "basic" },
        "tier_3_4": { "skill_count": 2, "pool": "intermediate" },
        "tier_5_6": { "skill_count": 2, "pool": "advanced" },
        "tier_7_8": { "skill_count": 3, "pool": "ultimate" },
        "boss":     { "skill_count_bonus": 1, "has_passive": true, "note": "Boss比同tier小怪多1个技能，且拥有Boss被动" }
      }
    }
  },

